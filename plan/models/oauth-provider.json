{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "OAuthProvider",
  "description": "Model konfiguracji providera OAuth",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid",
      "description": "Unikalny identyfikator providera"
    },
    "name": {
      "type": "string",
      "description": "Nazwa providera (np. 'google', 'keycloak')",
      "maxLength": 50
    },
    "displayName": {
      "type": "string",
      "description": "Wyświetlana nazwa (np. 'Google', 'Keycloak')",
      "maxLength": 100
    },
    "type": {
      "type": "string",
      "enum": ["OAuth2", "OIDC", "OAuth1"],
      "description": "Typ providera"
    },
    "authorizationEndpoint": {
      "type": "string",
      "format": "uri",
      "description": "Endpoint autoryzacji"
    },
    "tokenEndpoint": {
      "type": "string",
      "format": "uri",
      "description": "Endpoint tokena"
    },
    "userInfoEndpoint": {
      "type": "string",
      "format": "uri",
      "description": "Endpoint informacji o użytkowniku"
    },
    "clientId": {
      "type": "string",
      "description": "Client ID (encrypted)",
      "readOnly": true
    },
    "clientSecret": {
      "type": "string",
      "description": "Client Secret (encrypted)",
      "readOnly": true
    },
    "scopes": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Zakresy uprawnień"
    },
    "redirectUri": {
      "type": "string",
      "format": "uri",
      "description": "Redirect URI"
    },
    "isEnabled": {
      "type": "boolean",
      "description": "Czy provider jest włączony",
      "default": true
    },
    "order": {
      "type": "integer",
      "description": "Kolejność wyświetlania w UI",
      "default": 0
    },
    "iconUrl": {
      "type": "string",
      "format": "uri",
      "description": "URL ikony providera",
      "nullable": true
    },
    "createdAt": {
      "type": "string",
      "format": "date-time",
      "description": "Data utworzenia"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time",
      "description": "Data ostatniej aktualizacji",
      "nullable": true
    }
  },
  "required": ["id", "name", "displayName", "type", "authorizationEndpoint", "tokenEndpoint", "isEnabled", "createdAt"],
  "additionalProperties": false
}


