{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SmsCredential",
  "description": "Model credential SMS 2FA",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid",
      "description": "Unikalny identyfikator credential"
    },
    "userId": {
      "type": "string",
      "format": "uuid",
      "description": "Identyfikator użytkownika"
    },
    "phoneNumber": {
      "type": "string",
      "description": "Numer telefonu (encrypted)",
      "readOnly": true
    },
    "isEnabled": {
      "type": "boolean",
      "description": "Czy SMS 2FA jest włączony",
      "default": false
    },
    "isVerified": {
      "type": "boolean",
      "description": "Czy numer telefonu został zweryfikowany",
      "default": false
    },
    "createdAt": {
      "type": "string",
      "format": "date-time",
      "description": "Data utworzenia"
    },
    "verifiedAt": {
      "type": "string",
      "format": "date-time",
      "description": "Data weryfikacji",
      "nullable": true
    }
  },
  "required": ["id", "userId", "phoneNumber", "isEnabled", "isVerified", "createdAt"],
  "additionalProperties": false
}


