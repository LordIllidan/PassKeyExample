{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PasskeyCredential",
  "description": "Model credential passkey (WebAuthn)",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid",
      "description": "Unikalny identyfikator credential"
    },
    "userId": {
      "type": "string",
      "format": "uuid",
      "description": "Identyfikator użytkownika"
    },
    "credentialId": {
      "type": "string",
      "description": "Identyfikator credential (Base64 encoded)"
    },
    "publicKey": {
      "type": "string",
      "description": "Klucz publiczny (JSON encoded)"
    },
    "counter": {
      "type": "integer",
      "description": "Counter dla ochrony przed replay attacks",
      "minimum": 0
    },
    "name": {
      "type": "string",
      "description": "Nazwa urządzenia (user-friendly)",
      "maxLength": 255
    },
    "deviceType": {
      "type": "string",
      "enum": ["platform", "cross-platform"],
      "description": "Typ authenticatora"
    },
    "userAgent": {
      "type": "string",
      "description": "User agent przeglądarki",
      "nullable": true
    },
    "createdAt": {
      "type": "string",
      "format": "date-time",
      "description": "Data utworzenia"
    },
    "lastUsedAt": {
      "type": "string",
      "format": "date-time",
      "description": "Data ostatniego użycia",
      "nullable": true
    }
  },
  "required": ["id", "userId", "credentialId", "publicKey", "counter", "createdAt"],
  "additionalProperties": false
}


