{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "OAuthCredential",
  "description": "Model credential OAuth użytkownika",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid",
      "description": "Unikalny identyfikator credential"
    },
    "userId": {
      "type": "string",
      "format": "uuid",
      "description": "Identyfikator użytkownika"
    },
    "providerId": {
      "type": "string",
      "format": "uuid",
      "description": "Identyfikator providera OAuth"
    },
    "externalUserId": {
      "type": "string",
      "description": "Identyfikator użytkownika z providera"
    },
    "email": {
      "type": "string",
      "format": "email",
      "description": "Email z providera",
      "nullable": true
    },
    "accessToken": {
      "type": "string",
      "description": "Access token (encrypted, optional)",
      "readOnly": true,
      "nullable": true
    },
    "refreshToken": {
      "type": "string",
      "description": "Refresh token (encrypted, optional)",
      "readOnly": true,
      "nullable": true
    },
    "tokenExpiresAt": {
      "type": "string",
      "format": "date-time",
      "description": "Data wygaśnięcia tokena",
      "nullable": true
    },
    "createdAt": {
      "type": "string",
      "format": "date-time",
      "description": "Data utworzenia"
    },
    "lastUsedAt": {
      "type": "string",
      "format": "date-time",
      "description": "Data ostatniego użycia",
      "nullable": true
    }
  },
  "required": ["id", "userId", "providerId", "externalUserId", "createdAt"],
  "additionalProperties": false
}


