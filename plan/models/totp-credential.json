{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "TotpCredential",
  "description": "Model credential TOTP 2FA",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid",
      "description": "Unikalny identyfikator credential"
    },
    "userId": {
      "type": "string",
      "format": "uuid",
      "description": "Identyfikator użytkownika"
    },
    "secretKey": {
      "type": "string",
      "description": "Secret key (encrypted)",
      "readOnly": true
    },
    "isEnabled": {
      "type": "boolean",
      "description": "Czy TOTP jest włączony",
      "default": false
    },
    "createdAt": {
      "type": "string",
      "format": "date-time",
      "description": "Data utworzenia"
    },
    "verifiedAt": {
      "type": "string",
      "format": "date-time",
      "description": "Data weryfikacji",
      "nullable": true
    },
    "isRecoveryMode": {
      "type": "boolean",
      "description": "Czy jest w trybie recovery",
      "default": false
    },
    "recoveryStartedAt": {
      "type": "string",
      "format": "date-time",
      "description": "Data rozpoczęcia recovery",
      "nullable": true
    }
  },
  "required": ["id", "userId", "secretKey", "isEnabled", "createdAt"],
  "additionalProperties": false
}


