{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Permissions",
  "description": "Definicja wszystkich uprawnień w systemie",
  "type": "object",
  "properties": {
    "permissions": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/Permission"
      }
    }
  },
  "definitions": {
    "Permission": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Nazwa uprawnienia (format: resource:action:scope)"
        },
        "displayName": {
          "type": "string",
          "description": "Wyświetlana nazwa uprawnienia"
        },
        "description": {
          "type": "string",
          "description": "Opis uprawnienia"
        },
        "category": {
          "type": "string",
          "description": "Kategoria uprawnienia"
        }
      },
      "required": ["name", "displayName", "category"]
    }
  },
  "permissions": [
