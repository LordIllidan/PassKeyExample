{
  "openapi": "3.0.0",
  "info": {
    "title": "Admin API",
    "version": "1.0.0",
    "description": "API do zarządzania administracyjnego"
  },
  "servers": [
    {
      "url": "https://api.example.com/api/v1",
      "description": "Production server"
    }
  ],
  "paths": {
    "/admin/users": {
      "get": {
        "tags": ["Admin"],
        "summary": "Lista wszystkich użytkowników (admin)",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 1
            }
          },
          {
            "name": "pageSize",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 20
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Lista użytkowników",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PagedResult"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          }
        }
      }
    },
    "/admin/users/{id}/lock": {
      "post": {
        "tags": ["Admin"],
        "summary": "Zablokowanie użytkownika",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Użytkownik zablokowany"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          }
        }
      }
    },
    "/admin/users/{id}/unlock": {
      "post": {
        "tags": ["Admin"],
        "summary": "Odblokowanie użytkownika",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Użytkownik odblokowany"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          }
        }
      }
    },
    "/admin/oauth-providers": {
      "get": {
        "tags": ["Admin"],
        "summary": "Lista providerów OAuth",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Lista providerów",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/OAuthProvider"
                  }
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          }
        }
      },
      "post": {
        "tags": ["Admin"],
        "summary": "Dodanie providera OAuth",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateOAuthProviderRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Provider utworzony",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OAuthProvider"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          }
        }
      }
    },
    "/admin/ip-whitelist": {
      "get": {
        "tags": ["Admin"],
        "summary": "Lista IP whitelist",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Lista IP",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/IpFilter"
                  }
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          }
        }
      },
      "post": {
        "tags": ["Admin"],
        "summary": "Dodanie IP do whitelist",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["ipAddress"],
                "properties": {
                  "ipAddress": {
                    "type": "string",
                    "format": "ipv4"
                  },
                  "reason": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "IP dodane do whitelist"
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          }
        }
      }
    },
    "/admin/ip-blacklist": {
      "get": {
        "tags": ["Admin"],
        "summary": "Lista IP blacklist",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Lista IP",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/IpFilter"
                  }
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          }
        }
      },
      "post": {
        "tags": ["Admin"],
        "summary": "Dodanie IP do blacklist",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["ipAddress"],
                "properties": {
                  "ipAddress": {
                    "type": "string",
                    "format": "ipv4"
                  },
                  "reason": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "IP dodane do blacklist"
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "OAuthProvider": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "name": {
            "type": "string"
          },
          "displayName": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": ["OAuth2", "OIDC", "OAuth1"]
          },
          "isEnabled": {
            "type": "boolean"
          },
          "order": {
            "type": "integer"
          },
          "iconUrl": {
            "type": "string",
            "format": "uri"
          }
        }
      },
      "CreateOAuthProviderRequest": {
        "type": "object",
        "required": ["name", "displayName", "type", "authorizationEndpoint", "tokenEndpoint", "clientId", "clientSecret"],
        "properties": {
          "name": {
            "type": "string"
          },
          "displayName": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": ["OAuth2", "OIDC", "OAuth1"]
          },
          "authorizationEndpoint": {
            "type": "string",
            "format": "uri"
          },
          "tokenEndpoint": {
            "type": "string",
            "format": "uri"
          },
          "userInfoEndpoint": {
            "type": "string",
            "format": "uri"
          },
          "clientId": {
            "type": "string"
          },
          "clientSecret": {
            "type": "string"
          },
          "scopes": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "redirectUri": {
            "type": "string",
            "format": "uri"
          }
        }
      },
      "IpFilter": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "ipAddress": {
            "type": "string",
            "format": "ipv4"
          },
          "type": {
            "type": "string",
            "enum": ["Whitelist", "Blacklist"]
          },
          "reason": {
            "type": "string"
          },
          "isActive": {
            "type": "boolean"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "PagedResult": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array"
          },
          "pagination": {
            "type": "object",
            "properties": {
              "page": {
                "type": "integer"
              },
              "pageSize": {
                "type": "integer"
              },
              "totalCount": {
                "type": "integer"
              },
              "totalPages": {
                "type": "integer"
              }
            }
          }
        }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Nieprawidłowe żądanie"
      },
      "Unauthorized": {
        "description": "Brak autoryzacji"
      },
      "Forbidden": {
        "description": "Brak uprawnień"
      }
    },
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  }
}


