{
	"$schema": "./node_modules/@angular/cli/lib/config/schema.json",
	"version": 1,
	"newProjectRoot": "projects",
	"projects": {
		"passkey-auth-frontend": {
			"projectType": "application",
			"schematics": {
				"@schematics/angular:component": {
					"standalone": true,
					"style": "css"
				}
			},
			"root": "",
			"sourceRoot": "src",
			"prefix": "app",
			"architect": {
				"build": {
					"builder": "@angular/build:application",
					"options": {
						"outputPath": "dist/passkey-auth-frontend",
						"index": "src/index.html",
						"browser": "src/main.ts",
						"polyfills": [
							"zone.js"
						],
						"tsConfig": "tsconfig.app.json",
						"assets": [],
						"styles": [],
						"scripts": []
					},
					"configurations": {
						"production": {
							"optimization": true,
							"outputHashing": "all",
							"sourceMap": false,
							"namedChunks": false,
							"extractLicenses": true
						},
						"development": {
							"optimization": false,
							"sourceMap": true,
							"namedChunks": true,
							"extractLicenses": false
						}
					},
					"defaultConfiguration": "production"
				},
				"serve": {
					"builder": "@angular/build:application:dev-server",
					"options": {
						"buildTarget": "passkey-auth-frontend:build",
						"port": 4200
					},
					"configurations": {
						"production": {
							"buildTarget": "passkey-auth-frontend:build:production"
						},
						"development": {
							"buildTarget": "passkey-auth-frontend:build:development"
						}
					}
				}
			}
		}
	}
}